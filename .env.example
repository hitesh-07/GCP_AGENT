# Copy this file to .env for local reference. Never commit the real .env file.
GOOGLE_CLOUD_PROJECT=your-project-id
TASKS_LOCATION=us-east1
TASKS_QUEUE=gemini-requests
WORKER_URL=https://your-cloud-run-service.run.app/internal/tasks/generate
TASKS_SERVICE_ACCOUNT=gemini-gateway-dispatcher@your-project-id.iam.gserviceaccount.com

GEMINI_BACKEND=vertex
GOOGLE_CLOUD_LOCATION=global
GEMINI_MODEL=gemini-2.5-flash
TASK_MAX_ATTEMPTS=5
JOB_TTL_HOURS=24

# Only required when GEMINI_BACKEND=developer. Keep the real value in a secret manager.
GEMINI_API_KEY=
